# أكاديمية الإحسان - Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real keys.

# Gemini API key (https://aistudio.google.com/apikey)
# Production/serverless: keep this server-side. Do not expose it as VITE_*.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use. Free tier recommended for this tutor: gemini-2.5-flash.
# Lower-latency/budget option: gemini-2.5-flash-lite.
GEMINI_MODEL=gemini-2.5-flash

# Custom endpoint (optional). Defaults to the official Google endpoint.
# GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
