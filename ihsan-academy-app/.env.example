# Gemini API key for the AI Tutor module
# Must be prefixed with VITE_ or Vite will not expose it to the client bundle.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (override to use a different one)
VITE_GEMINI_MODEL=gemini-2.5-flash

# Optional: Override base API endpoint (rare)
VITE_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com